#!/usr/bin/env bash
# SessionStart card for the just-enough plugin. Injects a short standing reminder
# once per session so the restraint discipline is present without a per-turn
# injection hook or a mode system. Soft context, never blocks, adds no latency.
set -uo pipefail
case ",${JUST_ENOUGH_DISABLED_HOOKS:-}," in *",session-start,"*) exit 0 ;; esac

card="<system-reminder>
just-enough is active. When writing or editing ANY code, before adding a function, file, dependency, or abstraction, invoke the just-enough skill via the Skill tool and walk the reuse ladder: does this need to exist? → reuse what's already here → standard library → native feature → existing dependency → minimal code. Stop at the first rung that works, and write the result so a teammate reads it in one pass — minimal and READABLE, never a golfed one-liner. The best code is the code you never wrote.
</system-reminder>"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"; s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"; s="${s//$'\r'/\\r}"; s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}
card_escaped=$(escape_for_json "$card")

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$card_escaped"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$card_escaped"
fi
exit 0
